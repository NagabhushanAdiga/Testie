# Copy this to .env and fill in your values

# Path to Firebase service account JSON (download from Firebase Console > Project Settings > Service accounts > Generate new private key)
# Either set the path:
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Or paste the full JSON as a single line (alternative):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

PORT=4000
